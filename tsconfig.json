{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "playwright.config.ts",
    "global-setup.ts",
    "global-teardown.ts",
    "support/**/*.ts",
    ".agents/didaxis-program-deleter/scripts/**/*.ts"
  ]
}
