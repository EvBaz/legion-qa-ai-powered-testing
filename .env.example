# =============================================================================
# Run tests (required to clone and run Playwright)
# =============================================================================

# Didaxis app base URL used as Playwright baseURL (trailing slash optional)
DIDAXIS_URL=https://test.didaxis.studio/

# Primary test account email — used by auth.setup.ts for storageState login
DIDAXIS_EMAIL=your-email@example.com

# Password for DIDAXIS_EMAIL
DIDAXIS_PASSWORD=your-password-here

# Bearer token for program API cleanup (DELETE /api/programs) and API helpers
DIDAXIS_API_TOKEN=your-api-token-here

# --- Optional: secondary account for permission probes ---

# Alternate Didaxis login for role / permission boundary tests
DIDAXIS_ALT_EMAIL=alt-email@example.com

# Password for DIDAXIS_ALT_EMAIL
DIDAXIS_ALT_PASSWORD=alt-password-here

# =============================================================================
# Agent / CI setup (not needed for npx playwright test alone)
# =============================================================================

# Cursor API key for the headless agent in .github/workflows/test-generation.yml
CURSOR_API_KEY=your-cursor-api-key

# Atlassian Cloud API token — Jira REST in CI and Atlassian MCP in Cursor settings
ATLASSIAN_API_TOKEN=your-atlassian-api-token

# Atlassian Cloud site URL (e.g. https://your-org.atlassian.net)
ATLASSIAN_BASE_URL=https://your-org.atlassian.net

# Atlassian account email paired with ATLASSIAN_API_TOKEN
ATLASSIAN_EMAIL=your-atlassian-email@example.com
